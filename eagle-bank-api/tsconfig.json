{
	"compilerOptions": {
		"target": "ES2020",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"rootDir": "src",
		"outDir": "dist",
		"strict": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
        "noUncheckedIndexedAccess": true,
		"typeRoots": ["src/api-types"]
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist"]
}
